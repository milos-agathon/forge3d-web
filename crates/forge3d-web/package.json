{
  "name": "@forge3d/web",
  "version": "1.26.0",
  "type": "module",
  "description": "Browser-only Forge3D WebGPU/WASM runtime for terrain rendering",
  "license": "Apache-2.0 OR MIT",
  "homepage": "https://forge3d.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/milos-agathon/forge3d.git",
    "directory": "crates/forge3d-web"
  },
  "bugs": {
    "url": "https://github.com/milos-agathon/forge3d/issues"
  },
  "keywords": [
    "webgpu",
    "wasm",
    "terrain",
    "geospatial",
    "visualization"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "docs",
    "types",
    "README.md",
    "LICENSE",
    "LICENSE-APACHE"
  ],
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wasm": "./dist/forge3d_web_bg.wasm"
  },
  "types": "./types/index.d.ts",
  "scripts": {
    "build:wasm": "wasm-pack build . --target web --out-dir pkg --out-name forge3d_web",
    "build:ts": "tsc -p tsconfig.json",
    "prepare-dist": "node scripts/prepare-dist.mjs",
    "build:example": "npm --prefix examples/vite install --package-lock=false && npm --prefix examples/vite run build",
    "build": "npm run build:wasm && npm run build:ts && npm run prepare-dist && npm run build:example",
    "dev": "vite --host 127.0.0.1 --port 57883 --strictPort",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.api.json",
    "test:api": "npm run typecheck && node tests/api/public-api-snapshot.mjs",
    "test:release-hardening": "node tests/api/release-hardening.mjs",
    "test:package": "npm run test:release-hardening && node tests/api/package-contract.mjs",
    "test:browser": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wasm-pack": "^0.15.0"
  }
}
